/** Helper para catálogos (id => texto) */
function fetchPairs(PDO $pdo, string $sql, string $key = 'id', string $label = 'nombre'): array {
  $out = [];
  try {
    $st = $pdo->query($sql);
    if ($st) {
      while ($r = $st->fetch(PDO::FETCH_ASSOC)) {
        $out[$r[$key]] = $r[$label];
      }
    }
  } catch (Throwable $e) {
    // Ignora error pero deja registro en log
    error_log($e->getMessage());
  }
  return $out;
}

/* === Catálogos === */
$empresas  = fetchPairs($pdo, "SELECT id, nombre FROM ceo_empresas ORDER BY nombre");
$procesos  = fetchPairs($pdo, "SELECT id, desc_proceso AS nombre FROM ceo_procesos ORDER BY desc_proceso");
