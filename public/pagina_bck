function renderSemana() {
  const cont = document.getElementById('tablaSemana');

  // Base en lunes calculado por PHP (ya es el lunes de la semana actual)
  const lunesBase = new Date("<?= $lunes->format('Y-m-d') ?>T00:00:00");

  const dias = ['Lun','Mar','Mié','Jue','Vie'];
  let header = '<tr><th>Patio</th>';
  const fechas = [];

  // Genera lunes a viernes correctamente
  for (let i = 0; i < 5; i++) {
    const d = new Date(lunesBase);
    d.setDate(lunesBase.getDate() + i);

    const yyyyMMdd = d.toISOString().split('T')[0];
    fechas.push(yyyyMMdd);

    // Mostrar fecha sin depender del locale del navegador
    const dd = String(d.getDate()).padStart(2, '0');
    const mm = String(d.getMonth() + 1).padStart(2, '0');
    const yy = d.getFullYear();
    header += `<th>${dias[i]}<br>${dd}-${mm}-${yy}</th>`;
  }
  header += '</tr>';

  let body = '';
  <?php foreach ($patiosSemana as $p): ?>
    body += `<tr><td><?= esc($p['desc_patios']) ?></td>`;
    for (let f of fechas) {
      const ocupado = ocupacionesSemana.find(o => Number(o.id_patio) === <?= (int)$p['id'] ?> && o.fecha === f);
      if (ocupado) {
        body += `<td class="ocupado" title="Ocupado #${ocupado.nsolicitud || ''}">❌</td>`;
      } else {
        body += `<td><input type="checkbox" data-patio="<?= (int)$p['id'] ?>" data-fecha="${f}"></td>`;
      }
    }
    body += '</tr>';
  <?php endforeach; ?>

  cont.innerHTML = `<table class="table table-bordered table-sm text-center semana-tabla">
    <thead>${header}</thead><tbody>${body}</tbody></table>`;
}



// === Participantes ===
let _rows=[];

async function cargarParticipantes(){
  const cont = document.getElementById('tablaParticipantes');
  try {
    const r = await fetch('leer_excel.php');
    if (!r.ok) throw new Error('Respuesta HTTP ' + r.status);
    const j = await r.json();

    // Si el archivo no existe todavía
    if (!j.ok && j.error && j.error.includes('No se encontró')) {
      cont.innerHTML = `
        <div class="text-muted py-4">
          <i class="bi bi-info-circle me-2"></i>
          Aún no se ha cargado un archivo Excel. 
          <br>Utiliza el botón <strong>“Cargar Excel”</strong> para incorporar los participantes.
        </div>`;
      return;
    }

    if (j.ok) {
      _rows = j.rows || [];
      renderTablaCondensada(_rows);
    } else {
      cont.innerHTML = `<div class="text-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>
        ${j.error || 'Debe cargar un archivo Excel para visualizar los participantes.'}
      </div>`;
    }
  } catch (e) {
    console.error('Error cargar participantes', e);
    cont.innerHTML = `
      <div class="text-muted py-4">
        <i class="bi bi-info-circle me-2"></i>
        Esperando carga de archivo Excel...
      </div>`;
  }
}


function trimEmptyRows(rows){return (rows||[]).filter(r=>Array.isArray(r)&&r.some(c=>String(c||'').trim()!==''));}
function looksLikeHeader(row){const j=(row||[]).join(' ').toUpperCase();return j.includes('RUT')||j.includes('APELLIDO')||j.includes('CARGO');}

function renderTablaCondensada(rows){
  const clean=trimEmptyRows(rows);
  const cont=document.getElementById('tablaParticipantes');
  if(!clean.length){cont.innerHTML='<div class="text-muted py-4">Sin datos</div>';return;}
  const hdr=(clean[0]||[]).map(c=>String(c||'').toUpperCase().trim());
  const idx={
    rut:hdr.findIndex(h=>h.includes('RUT')),
    nombre:hdr.findIndex(h=>h.includes('NOMBRE')),
    ap1:hdr.findIndex(h=>h.includes('PATERNO')),
    ap2:hdr.findIndex(h=>h.includes('MATERNO')),
    cargo:hdr.findIndex(h=>h.includes('CARGO'))
  };
  const start=looksLikeHeader(clean[0])?1:0;
  let html='<table class="table table-bordered table-sm"><thead><tr><th>RUT</th><th>Nombre</th><th>1° Apellido</th><th>2° Apellido</th><th>Cargo</th></tr></thead><tbody>';
  for(let i=start;i<clean.length;i++){
    const r=clean[i];
    html+=`<tr><td>${r[idx.rut]||''}</td><td>${r[idx.nombre]||''}</td><td>${r[idx.ap1]||''}</td><td>${r[idx.ap2]||''}</td><td>${r[idx.cargo]||''}</td></tr>`;
  }
  html+='</tbody></table>';
  cont.innerHTML=html;
}

function renderTablaCompleta(rows){
  const clean=trimEmptyRows(rows);
  const cont=document.getElementById('tablaParticipantes');
  if(!clean.length){cont.innerHTML='<div class="text-muted py-4">Sin datos</div>';return;}
  const numCols=Math.max(...clean.map(r=>r.length));
  let html='<table class="table table-bordered table-sm"><thead><tr>';
  for(let i=0;i<numCols;i++)html+=`<th>${String.fromCharCode(65+i)}</th>`;
  html+='</tr></thead><tbody>';
  clean.forEach(r=>{html+='<tr>'+r.map(c=>`<td>${c||''}</td>`).join('')+'</tr>';});
  html+='</tbody></table>';
  cont.innerHTML=html;
}

window.addEventListener('DOMContentLoaded',()=>{
  renderSemana();
  cargarParticipantes();
  document.getElementById('btnTablaCompleta').onclick=()=>renderTablaCompleta(_rows);
  document.getElementById('btnTablaCondensada').onclick=()=>renderTablaCondensada(_rows);
});

// === Carga manual de Excel ===
document.getElementById('inputExcel').addEventListener('change', async function() {
  const file = this.files[0];
  if (!file) return;

  const formData = new FormData();
  formData.append('excel', file);

  const cont = document.getElementById('tablaParticipantes');
  cont.innerHTML = '<div class="text-muted py-4">Leyendo archivo...</div>';

  try {
    const resp = await fetch('leer_excel.php', { method: 'POST', body: formData });
    const data = await resp.json();
    if (data.ok) {
      _rows = data.rows || [];
      renderTablaCondensada(_rows);
    } else {
      cont.innerHTML = `<div class="text-danger">${data.error || 'Error al procesar el archivo.'}</div>`;
    }
  } catch (err) {
    console.error('Error leyendo Excel:', err);
    cont.innerHTML = '<div class="text-danger">Error al leer el archivo Excel.</div>';
  }
});
// === Carga dinámica de servicios por UO ===
(function() {
  const selUO = document.getElementById('selUO');
  const selSrv = document.getElementById('selServicio');

  if (selUO && selSrv) {
    selUO.addEventListener('change', async function () {
      const uoId = this.value;
      selSrv.innerHTML = '<option value="">Cargando servicios...</option>';
      if (!uoId) {
        selSrv.innerHTML = '<option value="">— Seleccionar UO primero —</option>';
        return;
      }
      try {
        const r = await fetch(`nueva_solicitud.php?action=servicios_by_uo&uo_id=${encodeURIComponent(uoId)}`);
        const data = await r.json();
        let opts = '<option value="">— Seleccionar —</option>';
        data.forEach(s => { opts += `<option value="${s.id}">${s.text}</option>`; });
        selSrv.innerHTML = opts || '<option value="">(Sin servicios para esta UO)</option>';
      } catch (e) {
        console.error(e);
        selSrv.innerHTML = '<option value="">Error al cargar servicios</option>';
      }
    });
  }
})();

